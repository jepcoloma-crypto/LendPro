# Copy this file to server\.env.production and fill in your production DB credentials
# This file is gitignored — production secrets stay local
#
#   copy sync\.env.production.example server\.env.production
#   # Then edit server\.env.production with real values
#
# Run sync\sync-prod-db.cmd to apply migrations to production.

PORT=5000
NODE_ENV=production

DB_HOST=your-production-db.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-production-password
DB_SSL=true

JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-refresh-secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@lendingapp.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=lending-documents

FRONTEND_URL=https://lendpro-seven.vercel.app
ALLOWED_ORIGINS=https://lendpro-seven.vercel.app
